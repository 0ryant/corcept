{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Claude Code Hook Envelope",
  "type": "object",
  "required": [
    "hook_event_name"
  ],
  "properties": {
    "session_id": {
      "type": "string"
    },
    "transcript_path": {
      "type": "string"
    },
    "cwd": {
      "type": "string"
    },
    "permission_mode": {
      "type": "string"
    },
    "hook_event_name": {
      "type": "string"
    },
    "tool_name": {
      "type": "string"
    },
    "tool_input": {
      "type": "object"
    },
    "tool_response": {},
    "tool_use_id": {
      "type": "string"
    },
    "prompt": {
      "type": "string"
    },
    "stop_hook_active": {
      "type": "boolean"
    },
    "agent_id": {
      "type": "string"
    },
    "agent_type": {
      "type": "string"
    }
  },
  "additionalProperties": true
}
