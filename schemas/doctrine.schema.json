{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CORCEPT Doctrine Rule",
  "type": "object",
  "required": [
    "id",
    "title",
    "authority",
    "status",
    "rule"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "authority": {
      "type": "string"
    },
    "scope": {
      "type": "object"
    },
    "status": {
      "type": "string"
    },
    "created_at": {
      "type": "string"
    },
    "created_by": {
      "type": "string"
    },
    "supersedes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "rule": {
      "type": "string"
    },
    "rationale": {
      "type": "string"
    }
  }
}
