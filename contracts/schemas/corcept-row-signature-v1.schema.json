{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.corcept.dev/corcept-row-signature-v1.schema.json",
  "title": "CORCEPT Row Signature v1",
  "type": "object",
  "required": ["schema_version", "key_id", "signed_at", "bytes"],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "type": "integer", "minimum": 1 },
    "key_id": { "type": "string", "pattern": "^fp:[0-9a-f]{32}$" },
    "signed_at": { "type": "string", "format": "date-time" },
    "bytes": { "type": "string", "minLength": 1 }
  }
}
